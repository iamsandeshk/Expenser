<?xml version="1.0" encoding="utf-8"?>
<!--
  Native Advanced Ad Layout for AdMob
  Designed to match app card style (dark theme, 36dp corner radius)
    Ad Unit: ca-app-pub-3940256099942544/2247696110
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1A1A1A"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Ad Badge Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Icon -->
                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/ad_icon_background" />

                <!-- Advertiser + Ad badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ad_advertiser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="Advertiser" />

                    <!-- Ad label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sponsored"
                        android:textSize="9sp"
                        android:textColor="#888888"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                </LinearLayout>

                <!-- Ad Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ad"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:background="@drawable/ad_badge_background"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </LinearLayout>

            <!-- Headline -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="6dp"
                android:text="Headline" />

            <!-- Body -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="12dp"
                android:text="Body text" />

            <!-- CTA Button -->
            <Button
                android:id="@+id/ad_call_to_action"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:text="Learn More"
                android:background="@drawable/ad_cta_background"
                android:textAllCaps="false" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</com.google.android.gms.ads.nativead.NativeAdView>
